# Test Environment Configuration
# Copy this file to .env and adjust values

# Database
DB_HOST=db
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_TABLE_PREFIX=wp_

# WordPress
# For Docker: use service name (http://wordpress) for inter-container communication
# For local: use http://localhost:8080
WP_URL=http://wordpress
WP_DOMAIN=wordpress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password
WP_ADMIN_EMAIL=admin@example.com

# Chrome/Selenium
CHROME_HOST=chrome
CHROME_PORT=4444

# Test admin user (created by tests)
TEST_ADMIN_USER=testadmin
TEST_ADMIN_PASSWORD=testpassword
