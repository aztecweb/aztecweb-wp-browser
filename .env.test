# Test Environment Configuration
# Used with: docker compose -f docker-compose.test.yml

# Database (Docker service name)
DB_HOST=db
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_TABLE_PREFIX=wp_

# WordPress (Docker service name for inter-container communication)
WP_URL=http://wordpress
WP_DOMAIN=wordpress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password
WP_ADMIN_EMAIL=admin@example.com

# Chrome/Selenium
CHROME_HOST=chrome
CHROME_PORT=4444

# Test admin user (created by tests)
TEST_ADMIN_USER=testadmin
TEST_ADMIN_PASSWORD=testpassword
